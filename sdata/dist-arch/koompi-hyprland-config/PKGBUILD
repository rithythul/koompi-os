# koompi-hyprland-config — ships the KOOMPI Hyprland dotfiles into /etc/skel so a
# freshly-created user inherits the whole desktop on first login.
#
# BUILD NOTE: via the existing sdata/dist-arch flow (plain makepkg in-tree) this
# reads ../../../dots through $startdir. For clean-chroot / repo builds (devtools,
# the koompi pacman repo), that relative tree is absent — switch `source` to a
# pinned git tag of this repo and copy from "$srcdir/koompi-hyprland/dots".
groups=(koompi)
pkgname=koompi-hyprland-config
pkgver=1.0
pkgrel=2
pkgdesc='KOOMPI Hyprland dotfiles, installed into /etc/skel for new users'
arch=(any)
license=(None)
# The config configures these; the full edition is pulled by koompi-desktop-hyprland.
depends=(koompi-hyprland koompi-quickshell-git)
# Mutually exclusive with the Plasma edition's /etc/skel layout: both ship the
# same shared KDE/Qt theming paths, so they conflict (one edition per machine).
conflicts=('koompi-kde-config')

package() {
  local _repo_root
  _repo_root="$(cd "$startdir/../../.." && pwd)"
  if [[ ! -d "$_repo_root/dots" ]]; then
    echo "koompi-hyprland-config: dots/ not found at repo root ($_repo_root)." >&2
    echo "Building in a clean chroot? Switch source to a pinned git tag (see header)." >&2
    return 1
  fi
  install -dm755 "$pkgdir/etc/skel"
  cp -a "$_repo_root/dots/." "$pkgdir/etc/skel/"
}
